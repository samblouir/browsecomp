# Model under evaluation. The API must implement POST /v1/chat/completions.
BC250_MODEL_API_BASE=http://127.0.0.1:8000/v1
BC250_MODEL_API_KEY=replace-me
# Set true only when the endpoint intentionally accepts unauthenticated requests.
BC250_ALLOW_EMPTY_MODEL_API_KEY=false
BC250_MODEL_NAME=star

# Optional JSON object of additional request headers, e.g. {"X-Tenant":"frontierrl"}
BC250_MODEL_EXTRA_HEADERS={}

# Fixed grader. For a public headline, use a stable, disclosed grader endpoint/model.
BC250_GRADER_API_BASE=https://api.openai.com/v1
BC250_GRADER_API_KEY=replace-me
BC250_ALLOW_EMPTY_GRADER_API_KEY=false
BC250_GRADER_MODEL=gpt-5.6
BC250_GRADER_EXTRA_HEADERS={}
BC250_GRADER_INPUT_PRICE_PER_MILLION=0
BC250_GRADER_OUTPUT_PRICE_PER_MILLION=0

# Search backend: openrouter_exa, brave, tavily, serper, searxng, or yahoo.
BC250_SEARCH_PROVIDER=brave
BC250_BRAVE_API_KEY=replace-me
BC250_OPENROUTER_API_KEY=replace-me
BC250_OPENROUTER_API_BASE=https://openrouter.ai/api/v1
BC250_OPENROUTER_SEARCH_MODEL=openai/gpt-4.1-nano
BC250_OPENROUTER_SEARCH_MAX_CONCURRENCY=32
BC250_TAVILY_API_KEY=replace-me
BC250_SERPER_API_KEY=replace-me
BC250_SEARXNG_BASE_URL=http://127.0.0.1:8080

# Optional expected SHA-256 for the official encrypted CSV after the first controlled download.
# Set this in your campaign configuration once recorded.
BC250_EXPECTED_DATASET_SHA256=

# Optional cost accounting for the evaluated model.
BC250_MODEL_INPUT_PRICE_PER_MILLION=0
BC250_MODEL_OUTPUT_PRICE_PER_MILLION=0

# Optional private transcript encryption. Generate with:
#   .venv/bin/python scripts/generate_fernet_key.py
BC250_ARTIFACT_FERNET_KEY=
